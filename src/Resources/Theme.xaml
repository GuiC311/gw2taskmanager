<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ============================================================
         GW2 TaskManager — Theme  (palette Proposée v2 — +contraste)
         Bronze/parchment dark palette, gold accents
         ============================================================ -->

    <!-- Colors — palette Warm/Proposée (défaut). Muté dynamiquement par ThemeManager. -->
    <Color x:Key="Bg0Color">#1C160F</Color>
    <Color x:Key="Bg1Color">#251C12</Color>
    <Color x:Key="Bg2Color">#32261A</Color>
    <Color x:Key="Bg3Color">#3E3022</Color>
    <Color x:Key="LineColor">#5A4633</Color>
    <Color x:Key="Text0Color">#F5EBDA</Color>
    <Color x:Key="Text1Color">#D4C4A4</Color>
    <Color x:Key="Text2Color">#A08868</Color>
    <Color x:Key="GoldColor">#D4A04A</Color>
    <Color x:Key="GoldSoftColor">#B88A3A</Color>
    <Color x:Key="GoldGlowColor">#FFCE6B</Color>
    <Color x:Key="AmberColor">#D6892E</Color>
    <Color x:Key="EmeraldColor">#4F9E6A</Color>
    <Color x:Key="EmeraldTextColor">#7EC999</Color>
    <Color x:Key="TimerGreenColor">#7EC999</Color>
    <Color x:Key="TimerYellowColor">#E3A35A</Color>
    <Color x:Key="TimerOrangeColor">#F0B266</Color>
    <Color x:Key="TimerRedColor">#E07070</Color>

    <!-- Brushes — po:Freeze="False" allows ThemeManager to mutate Color at runtime -->
    <SolidColorBrush x:Key="Bg0Brush"          po:Freeze="False" Color="{StaticResource Bg0Color}"/>
    <SolidColorBrush x:Key="Bg1Brush"          po:Freeze="False" Color="{StaticResource Bg1Color}"/>
    <SolidColorBrush x:Key="Bg2Brush"          po:Freeze="False" Color="{StaticResource Bg2Color}"/>
    <SolidColorBrush x:Key="Bg3Brush"          po:Freeze="False" Color="{StaticResource Bg3Color}"/>
    <SolidColorBrush x:Key="LineBrush"         po:Freeze="False" Color="{StaticResource LineColor}"/>
    <SolidColorBrush x:Key="Text0Brush"        po:Freeze="False" Color="{StaticResource Text0Color}"/>
    <SolidColorBrush x:Key="Text1Brush"        po:Freeze="False" Color="{StaticResource Text1Color}"/>
    <SolidColorBrush x:Key="Text2Brush"        po:Freeze="False" Color="{StaticResource Text2Color}"/>
    <SolidColorBrush x:Key="GoldBrush"         po:Freeze="False" Color="{StaticResource GoldColor}"/>
    <SolidColorBrush x:Key="GoldSoftBrush"     po:Freeze="False" Color="{StaticResource GoldSoftColor}"/>
    <SolidColorBrush x:Key="GoldGlowBrush"     po:Freeze="False" Color="{StaticResource GoldGlowColor}"/>
    <SolidColorBrush x:Key="AmberBrush"        po:Freeze="False" Color="{StaticResource AmberColor}"/>
    <SolidColorBrush x:Key="EmeraldBrush"      po:Freeze="False" Color="{StaticResource EmeraldColor}"/>
    <SolidColorBrush x:Key="EmeraldTextBrush"  po:Freeze="False" Color="{StaticResource EmeraldTextColor}"/>
    <SolidColorBrush x:Key="TimerGreenBrush"   po:Freeze="False" Color="{StaticResource TimerGreenColor}"/>
    <SolidColorBrush x:Key="TimerYellowBrush"  po:Freeze="False" Color="{StaticResource TimerYellowColor}"/>
    <SolidColorBrush x:Key="TimerOrangeBrush"  po:Freeze="False" Color="{StaticResource TimerOrangeColor}"/>
    <SolidColorBrush x:Key="TimerRedBrush"     po:Freeze="False" Color="{StaticResource TimerRedColor}"/>
    <SolidColorBrush x:Key="TransparentBrush"  Color="Transparent"/>

    <!-- Typography -->
    <FontFamily x:Key="MainFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New</FontFamily>
    <system:Double x:Key="FontSizeNormal" xmlns:system="clr-namespace:System;assembly=mscorlib">13</system:Double>
    <system:Double x:Key="FontSizeSmall"  xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
    <system:Double x:Key="FontSizeLarge"  xmlns:system="clr-namespace:System;assembly=mscorlib">15</system:Double>

    <!-- ============================================================
         Base control styles
         ============================================================ -->

    <!-- Window background -->
    <Style x:Key="AppWindowStyle" TargetType="Window">
        <Setter Property="Background"  Value="{DynamicResource Bg0Brush}"/>
        <Setter Property="FontFamily"  Value="{StaticResource MainFont}"/>
        <Setter Property="Foreground"  Value="{DynamicResource Text0Brush}"/>
    </Style>

    <!-- TextBlock defaults -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Text0Brush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeNormal}"/>
    </Style>

    <!-- ============================================================
         ScrollBar — slim dark thumb
         ============================================================ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{DynamicResource LineBrush}" CornerRadius="3" Margin="1,0"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Text2Brush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         TextBox — dark + gold focus ring
         ============================================================ -->
    <Style TargetType="TextBox">
        <Setter Property="Background"      Value="{DynamicResource Bg1Brush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource Text0Brush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="CaretBrush"      Value="{DynamicResource GoldBrush}"/>
        <Setter Property="SelectionBrush"  Value="{DynamicResource GoldSoftBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Text2Brush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsFocused"   Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource GoldBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         ComboBox — full dark ControlTemplate (no system-color leaks)
         ============================================================ -->

    <!-- ComboBoxItem -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource Text0Brush}"/>
        <Setter Property="Padding"         Value="10,6"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Bg3Brush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource Bg3Brush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"       Value="{DynamicResource Bg2Brush}"/>
        <Setter Property="Foreground"       Value="{DynamicResource Text0Brush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="8,5"/>
        <Setter Property="FontSize"         Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll"              Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="root" SnapsToDevicePixels="True">

                        <!-- Main box -->
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selected item -->
                                <ContentPresenter x:Name="contentSite"
                                                  Grid.Column="0"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                                <!-- Editable text box (IsEditable mode) -->
                                <TextBox x:Name="PART_EditableTextBox"
                                         Grid.Column="0"
                                         Style="{x:Null}"
                                         Background="Transparent"
                                         Foreground="{DynamicResource Text0Brush}"
                                         CaretBrush="{DynamicResource GoldBrush}"
                                         BorderThickness="0"
                                         Margin="{TemplateBinding Padding}"
                                         VerticalAlignment="Center"
                                         Visibility="Hidden"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Focusable="True"/>

                                <!-- Chevron arrow -->
                                <Path x:Name="arrow"
                                      Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="{DynamicResource Text2Brush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <!-- Invisible overlay toggle button (captures clicks) -->
                        <ToggleButton x:Name="PART_ToggleButton"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Dropdown popup -->
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="None">
                            <Border x:Name="dropBorder"
                                    MinWidth="{Binding ActualWidth,
                                                       RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{DynamicResource Bg2Brush}"
                                    BorderBrush="{DynamicResource GoldBrush}"
                                    BorderThickness="1"
                                    CornerRadius="0,0,4,4"
                                    Margin="0,1,0,0"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Text2Brush}"/>
                            <Setter TargetName="arrow"  Property="Stroke"      Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                        <!-- Open -->
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"  Value="{DynamicResource GoldBrush}"/>
                            <Setter TargetName="border" Property="CornerRadius"  Value="4,4,0,0"/>
                            <Setter TargetName="arrow"  Property="Stroke"       Value="{DynamicResource GoldBrush}"/>
                            <Setter TargetName="arrow"  Property="Data"         Value="M 0 4 L 4 0 L 8 4"/>
                        </Trigger>
                        <!-- Editable mode -->
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="contentSite"          Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         ToolTip — dark theme
         ============================================================ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"    Value="{DynamicResource Bg2Brush}"/>
        <Setter Property="Foreground"    Value="{DynamicResource Text0Brush}"/>
        <Setter Property="BorderBrush"   Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"       Value="9,5"/>
        <Setter Property="FontSize"      Value="12"/>
        <Setter Property="FontFamily"    Value="{StaticResource MainFont}"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Buttons
         ============================================================ -->

    <!-- Primary button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource GoldSoftBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource Bg0Brush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="14,8"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource GoldGlowBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost button -->
    <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Text1Brush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource GoldBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Bg2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Waypoint link button -->
    <Style x:Key="LinkButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource Bg0Brush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource GoldBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="FontFamily"      Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"   Value="{DynamicResource Bg3Brush}"/>
                            <Setter TargetName="border" Property="BorderBrush"  Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Tab button (RadioButton)
         ============================================================ -->
    <Style x:Key="TabButtonStyle" TargetType="RadioButton">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource Text1Brush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="18,12"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="FontWeight"      Value="Medium"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="indicator" Height="2" VerticalAlignment="Bottom"
                                Background="Transparent" CornerRadius="1"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource GoldBrush}"/>
                            <Setter TargetName="indicator" Property="Background" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background">
                                <Setter.Value><SolidColorBrush Color="#0AFFFFFF"/></Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Toggle switch (enable/disable objective)
         ============================================================ -->
    <Style x:Key="ToggleStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="36" Height="20">
                        <Border x:Name="track"
                                CornerRadius="10"
                                Background="{DynamicResource Bg3Brush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"/>
                        <Ellipse x:Name="thumb"
                                 Width="14" Height="14"
                                 Fill="{DynamicResource Text2Brush}"
                                 HorizontalAlignment="Left"
                                 Margin="3,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background"   Value="{DynamicResource GoldSoftBrush}"/>
                            <Setter TargetName="track" Property="BorderBrush"  Value="{DynamicResource GoldBrush}"/>
                            <Setter TargetName="thumb" Property="Fill"         Value="{DynamicResource Bg0Brush}"/>
                            <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="thumb" Property="Margin"       Value="0,0,3,0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Checkmark button (done/undone)
         ============================================================ -->
    <Style x:Key="CheckButtonStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="border"
                            Width="24" Height="24"
                            CornerRadius="6"
                            Background="{DynamicResource Bg1Brush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="2">
                        <TextBlock x:Name="check"
                                   Text="✓"
                                   Foreground="{DynamicResource Bg0Brush}"
                                   FontWeight="Black" FontSize="15"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background"   Value="{DynamicResource GoldBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush"  Value="{DynamicResource GoldGlowBrush}"/>
                            <Setter TargetName="check"  Property="Visibility"   Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource GoldBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Reusable border styles
         ============================================================ -->

    <!-- API status pill -->
    <Style x:Key="ApiStatusStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding"      Value="10,4"/>
    </Style>

    <!-- Section badge (Daily/Weekly/Done) -->
    <Style x:Key="BadgeDailyStyle" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource Bg2Brush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="3"/>
        <Setter Property="Padding"          Value="10,4"/>
    </Style>

    <Style x:Key="BadgeWeeklyStyle" TargetType="Border" BasedOn="{StaticResource BadgeDailyStyle}"/>
    <Style x:Key="BadgeDoneStyle"   TargetType="Border" BasedOn="{StaticResource BadgeDailyStyle}"/>

    <!-- Task row card -->
    <Style x:Key="TaskRowStyle" TargetType="Border">
        <Setter Property="Background"      Value="{DynamicResource Bg1Brush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="12,10"/>
        <Setter Property="Margin"          Value="0,2"/>
    </Style>

    <!-- Task row — done state -->
    <Style x:Key="TaskRowDoneStyle" TargetType="Border" BasedOn="{StaticResource TaskRowStyle}">
        <Setter Property="Opacity" Value="0.55"/>
    </Style>

    <!-- Reset chip -->
    <Style x:Key="ResetChipStyle" TargetType="Border">
        <Setter Property="Background"       Value="{DynamicResource Bg2Brush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="10,5"/>
    </Style>

    <!-- Separator -->
    <Style x:Key="SectionSeparatorStyle" TargetType="Border">
        <Setter Property="BorderBrush"     Value="{DynamicResource LineBrush}"/>
