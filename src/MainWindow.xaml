<Window x:Class="GW2TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:GW2TaskManager.Views"
        mc:Ignorable="d"
        Title="GW2 TaskManager"
        Icon="Resources/icon.ico"
        Height="800" Width="1100" MinHeight="600" MinWidth="900"
        Style="{StaticResource AppWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title bar -->
            <RowDefinition Height="Auto"/>  <!-- API bar -->
            <RowDefinition Height="Auto"/>  <!-- Tab bar -->
            <RowDefinition Height="*"/>     <!-- Page content -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- =============== Title bar =============== -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="LogoImage"
                           Width="34" Height="34" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           VerticalAlignment="Center"/>
                    <TextBlock Text="GW2 "       FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Text0Brush}" VerticalAlignment="Center"/>
                    <TextBlock Text="TaskManager" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource GoldBrush}"  VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Language + Theme toggles -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="LanguageToggleBtn"
                            ToolTip="{DynamicResource Str_LangTooltip}"
                            Style="{StaticResource GhostButtonStyle}"
                            Padding="8,4"
                            VerticalAlignment="Center"
                            Click="LanguageToggle_Click">
                        <Image Source="{DynamicResource FlagCurrent}"
                               Width="22" Height="15"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"/>
                    </Button>
                    <Button x:Name="ThemeToggleBtn"
                            Content="🌙"
                            ToolTip="{DynamicResource Str_ThemeTooltip}"
                            Style="{StaticResource GhostButtonStyle}"
                            FontSize="15" Padding="8,4"
                            VerticalAlignment="Center"
                            Click="ThemeToggle_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =============== API bar =============== -->
        <Border Grid.Row="1"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Str_ApiKeyLabel}" Foreground="{DynamicResource Text2Brush}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <!-- API key help -->
                <Border Width="16" Height="16" CornerRadius="8"
                        Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                        Margin="0,0,10,0" VerticalAlignment="Center" Cursor="Help"
                        ToolTipService.InitialShowDelay="0"
                        ToolTipService.ShowDuration="30000">
                    <Border.ToolTip>
                        <ToolTip MaxWidth="320">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Str_ApiHelpTitle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="{DynamicResource Str_ApiHelpBody}" TextWrapping="Wrap" Foreground="{DynamicResource Text1Brush}"/>
                                <TextBlock Margin="0,6,0,0" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                           Foreground="{DynamicResource GoldBrush}"
                                           Text="account · characters · progression"/>
                            </StackPanel>
                        </ToolTip>
                    </Border.ToolTip>
                    <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource Text2Brush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBox x:Name="ApiKeyBox" Width="460" FontFamily="Cascadia Mono, Consolas"
                         FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"
                         TextChanged="ApiKeyBox_TextChanged"/>
                <Border x:Name="ApiStatusBorder" Style="{StaticResource ApiStatusStyle}"
                        Background="#0D4F9E6A" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="ApiDot" Width="8" Height="8" Margin="0,0,6,0"
                                 Fill="{DynamicResource Text2Brush}"/>
                        <TextBlock x:Name="ApiStatusText" Text="{DynamicResource Str_ApiStatusNoKey}"
                                   Foreground="{DynamicResource Text2Brush}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Button x:Name="SyncNowButton" Content="↻" ToolTip="{DynamicResource Str_SyncTooltip}"
                        Style="{StaticResource GhostButtonStyle}"
                        FontSize="14" Padding="8,2" Margin="8,0,0,0"
                        Click="SyncNow_Click"/>
            </StackPanel>
        </Border>

        <!-- =============== Tab bar =============== -->
        <Border Grid.Row="2"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="TabTodo" Content="{DynamicResource Str_TabTodo}"
                             Style="{StaticResource TabButtonStyle}"
                             IsChecked="True"
                             Checked="TabTodo_Checked"/>
                <RadioButton x:Name="TabCatalog" Content="{DynamicResource Str_TabCatalog}"
                             Style="{StaticResource TabButtonStyle}"
                             Checked="TabCatalog_Checked"/>
            </StackPanel>
        </Border>

        <!-- =============== Page content =============== -->
        <Grid Grid.Row="3">
            <views:TodoView x:Name="TodoPage" Visibility="Visible"/>
            <views:CatalogView x:Name="CatalogPage" Visibility="Collapsed"/>
        </Grid>

        <!-- =============== Footer =============== -->
        <Border Grid.Row="4"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource Text2Brush}">
                <Run Text="{DynamicResource Str_FooterMadeBy}"/><Run Foreground="{DynamicResource GoldBrush}" FontWeight="SemiBold">FTs.1843</Run>
                <Run Text="{DynamicResource Str_FooterAnd}"/><Run Foreground="{DynamicResource GoldBrush}" FontWeight="SemiBold">Murran.3841</Run>
                <Run Text="{DynamicResource Str_FooterDonation}"/>
            </TextBlock>
        </Border>

    </Grid>
</Window>
