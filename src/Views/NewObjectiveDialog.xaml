<Window x:Class="GW2TaskManager.Views.NewObjectiveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_DialogTitle}"
        Width="460" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource Text2Brush}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldGroupStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Fields -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="+" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource GoldBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="{DynamicResource Str_DialogHeader}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource Text0Brush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,4">
            <StackPanel>

                <!-- Nom -->
                <StackPanel Style="{StaticResource FieldGroupStyle}">
                    <TextBlock Text="{DynamicResource Str_FieldName}" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="NameBox" FontSize="13"/>
                </StackPanel>

                <!-- Description -->
                <StackPanel Style="{StaticResource FieldGroupStyle}">
                    <TextBlock Text="{DynamicResource Str_FieldDescription}" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="DescBox" FontSize="13"/>
                </StackPanel>

                <!-- Type -->
                <StackPanel Style="{StaticResource FieldGroupStyle}">
                    <TextBlock Text="{DynamicResource Str_FieldType}" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="TypeBox" SelectedIndex="0" HorizontalAlignment="Left" Width="160">
                        <ComboBoxItem Content="Daily"/>
                        <ComboBoxItem Content="Weekly"/>
                    </ComboBox>
                </StackPanel>

                <!-- Icône + Personnage (même ligne) -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Str_FieldIcon}" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="IconBox" FontSize="18" MaxLength="4"
                                 HorizontalContentAlignment="Center" Padding="6,4"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource Str_FieldCharacter}" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="CharacterBox" IsEditable="True" FontSize="13" Text="Any"/>
                    </StackPanel>
                </Grid>

                <!-- Waypoint -->
                <StackPanel Style="{StaticResource FieldGroupStyle}">
                    <TextBlock Text="{DynamicResource Str_FieldWaypoint}" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="LinkBox" FontFamily="Cascadia Mono, Consolas"
                             FontSize="12" ToolTip="Ex : [&amp;BGQNAAA=]"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Str_BtnCancel}" Style="{StaticResource GhostButtonStyle}"
                        Padding="16,8" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button x:Name="CreateButton" Content="{DynamicResource Str_BtnCreate}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="16,8" Click="Create_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
