<Window x:Class="GW2TaskManager.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="340" Height="80"
        IsHitTestVisible="True">

    <Border Background="#1F1812"
            BorderBrush="#4A3A2A"
            BorderThickness="1"
            CornerRadius="10"
            Cursor="Hand"
            MouseLeftButtonDown="OnClick">

        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="4" Opacity="0.55"/>
        </Border.Effect>

        <Grid Margin="14,0,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Gold accent bar -->
            <Rectangle Grid.Column="0" Width="3" Height="44"
                       Fill="#D4A04A" RadiusX="2" RadiusY="2"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>

            <!-- Emoji icon -->
            <TextBlock Grid.Column="1"
                       x:Name="IconText"
                       FontSize="24"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

            <!-- Title + Subtitle -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#F1E6D0"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="11"
                           Foreground="#8A7A60"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
